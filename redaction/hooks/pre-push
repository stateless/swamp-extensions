#!/usr/bin/env bash
# pre-push — git hook: scan the working tree before it leaves the machine.
# Install in a repo via a tracked hooks dir (see install.sh): catches any pusher —
# human OR agent, any tool. Bypassable with --no-verify (so CI stays the floor).
# Exits non-zero → git aborts the push.
#
# Config (env, portable defaults):
#   REDACTION_DENO     - deno binary (default: PATH, then ~/.deno/bin/deno)
#   REDACTION_CLI      - cli.ts path (default: redaction/cli.ts or extensions/…)
#   REDACTION_DENYLIST - private denylist file (default: none → generic tier only)

set -euo pipefail
DENO="${REDACTION_DENO:-$(command -v deno || echo "$HOME/.deno/bin/deno")}"
CLI="${REDACTION_CLI:-}"
if [ -z "$CLI" ]; then
  for c in redaction/cli.ts extensions/models/redaction/cli.ts; do
    [ -f "$c" ] && CLI="$c" && break
  done
fi
DENY="${REDACTION_DENYLIST:-}"

# FAIL-OPEN on missing tooling (don't block a push because the guard is broken).
{ [ -x "$DENO" ] && [ -n "$CLI" ] && [ -f "$CLI" ]; } || { echo "pre-push: redaction tooling missing, skipping" >&2; exit 0; }

deny_args=()
[ -n "$DENY" ] && [ -f "$DENY" ] && deny_args=(--deny "$DENY")
exec "$DENO" run --allow-read "$CLI" "${deny_args[@]}" .
